# ==============================================================================
# PLANTILLA DE VARIABLES DE ENTORNO — NEXUS
# ==============================================================================
# Copia este archivo como .env y completa los valores reales:
#     cp .env.example .env        (Linux/Mac)
#     copy .env.example .env      (Windows)
#
# El archivo .env NO se sube al repositorio (está en .gitignore).
# ==============================================================================

# ── Seguridad ────────────────────────────────────────────────────────────────
# Genera una nueva con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=coloca-aqui-tu-clave-secreta

# DEBUG=True en desarrollo, False en producción
DEBUG=True

# Hosts permitidos separados por coma. En desarrollo: 127.0.0.1,localhost
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Base de datos (SQL Server) ───────────────────────────────────────────────
DB_NAME=nexus_db
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_HOST=nombre_del_servidor
DB_PORT=
DB_DRIVER='ODBC Driver 18 for SQL Server'
DB_EXTRA_PARAMS=TrustServerCertificate=yes;Encrypt=yes;
