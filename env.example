# ==============================================================================
# .env.example — Nexus | Grupo Carval
# ==============================================================================
# Copia este archivo como .env en la raíz del proyecto y completa los valores.
# NUNCA subas el archivo .env real al repositorio.
# ==============================================================================

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-cambia-esto-por-una-clave-segura-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos (SQL Server) ────────────────────────────────────────────────
DB_ENGINE=mssql
DB_NAME=nexus_db
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_HOST=nombre_servidor
DB_PORT=
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_CERT=yes
DB_ENCRYPT=yes

# ── Zona horaria ──────────────────────────────────────────────────────────────
TIME_ZONE=America/Bogota
LANGUAGE_CODE=es-co

# ── Caché (opcional — Redis en producción) ────────────────────────────────────
# CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
# CACHE_LOCATION=redis://127.0.0.1:6379/1
# CACHE_TIMEOUT=300
